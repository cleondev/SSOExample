{
  "MicrosoftEntraId": {
    "TenantId": "<azure-tenant-id>",
    "TenantName": "<your-tenant-name>.onmicrosoft.com",
    "Authority": "https://login.microsoftonline.com/<azure-tenant-id>/v2.0",
    "ClientId": "<ssoexample-web-app-client-id>",
    "RedirectUris": [
      "https://localhost:5002/auth/callback"
    ],
    "PostLogoutRedirectUri": "https://localhost:5002/",
    "Scopes": [
      "openid",
      "profile",
      "email",
      "api://<ssoexample-api-app-client-id>/access_as_user"
    ],
    "CacheLocation": "sessionStorage"
  },
  "Api": {
    "BaseUrl": "https://localhost:5001",
    "LocalDemoClientId": "ssoexample-web",
    "Audience": "api://<ssoexample-api-app-client-id>",
    "RequiredScope": "api://<ssoexample-api-app-client-id>/access_as_user"
  },
  "AllowedHosts": "*"
}
